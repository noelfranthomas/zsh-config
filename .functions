# ~/.functions

export SPECIAL_GP=~/Documents/GitHub
export SPECIAL_ZSH_CONFIG_PATH=~/Documents/GitHub/zsh-config
export SPECIAL_CONTACT_NUMBER_OR_EMAIL="5877009968"
export SPECIAL_LLM_URL="http://localhost:9191"

# --- Function registry ---
typeset -gA _fn_desc    # name -> description
typeset -gA _fn_usage   # name -> usage (optional)

# Register a function: _reg <name> <description> [usage]
_reg() {
  _fn_desc[$1]="$2"
  [[ -n "$3" ]] && _fn_usage[$1]="$3"
}

uzsh() {
  cp -f $SPECIAL_GP/zsh-config/.zshrc $HOME
  cp -f $SPECIAL_GP/zsh-config/.functions $HOME
  cp -f $SPECIAL_GP/zsh-config/.llm-functions $HOME
}
_reg uzsh "updates .zshrc, .functions, and .llm-functions"

wzsh() {
  "$EDITOR" $SPECIAL_ZSH_CONFIG_PATH
}
_reg wzsh "open the zsh-config files in the default editor"

checksite() {
  curl -Is "$1" | head -n 1
}
_reg checksite "check if a website is up" "checksite <url>"

portpid() {
  if [ -z "$1" ]; then
    echo "Usage: portpid <port>"
    return 1
  fi

  lsof -i :"$1" | awk 'NR>1 {print "Process Name: "$1, "PID: "$2}'
}
_reg portpid "find process name and PID by port" "portpid <port>"

genpass() {
  length="${1:-16}"
  if ! [[ "$length" =~ ^[0-9]+$ ]]; then
    echo "Invalid length specified. Please provide a numerical value."
    return 1
  fi
  LC_ALL=C tr -dc A-Za-z0-9 </dev/urandom | head -c "$length" ; echo ''
}
_reg genpass "generate a random password" "genpass [length]"

help() {
  if [[ -z "$1" ]]; then
    echo
    echo "This is a zsh config designed to reduce friction during everyday use."
    echo "Author: @noelfranthomas"
    echo

    echo "PARAMS: "

    if [[ $(setopt) == *autocd* ]]; then
      echo "\tautocd: \e[32menabled\e[0m"
    else
      echo "\tautocd: \e[31mdisabled\e[0m"
    fi

    if [[ $(setopt) == *correct* ]]; then
      echo "\tspellcheck: \e[32menabled\e[0m"
    else
      echo "\tspellcheck: \e[31mdisabled\e[0m"
    fi

    if [[ $CLICOLOR == 1 ]]; then
      echo "\tCLICOLOR: \e[32menabled\e[0m"
    else
      echo "\tCLICOLOR: \e[31mdisabled\e[0m"
    fi

    echo "\tEDITOR: \e[32m$EDITOR\e[0m"

    if [[ $LLM_AVAILABLE == 1 ]]; then
      echo "\tLLM_AVAILABLE: \e[32menabled\e[0m"
    else
      echo "\tLLM_AVAILABLE: $LLM_AVAILABLE"
    fi

    echo
    echo "Here is a list of functions that have been added to the config:"
    echo
    for fn in ${(ko)_fn_desc}; do
      printf "\033[1;34m%-16s\033[0m - %s\n" "$fn" "${_fn_desc[$fn]}"
    done
    echo
  else
    if [[ -n "${_fn_desc[$1]}" ]]; then
      echo
      printf "\033[1;34m%s\033[0m - %s\n" "$1" "${_fn_desc[$1]}"
      [[ -n "${_fn_usage[$1]}" ]] && printf "Usage: %s\n" "${_fn_usage[$1]}"
      echo
      printf "\033[2m"
      which "$1"
      printf "\033[0m"
    else
      echo "\nFunction \033[1;34m$1\033[0m not found."
    fi
    echo
  fi
}
_reg help "list all functions and descriptions" "help [function_name]"

ll() {
  ls -lah
}
_reg ll "ls -lah"

c() {
  echo "running claude"
  claude
}
_reg c "run coding agent"

up() {
  local d=""
  local limit="$1"
  for ((i=1 ; i <= limit ; i++)); do
    d="../$d"
  done
  cd "$d"
}
_reg up "go up multiple directories" "up <n>"

jkl() {
  cd $SPECIAL_GP
}
_reg jkl "go to the GitHub dir"

ga() {
  local path="${1:-.}"
  git add "$path"
}
_reg ga "git add shortcut" "ga [path]"

gs() {
  git status
}
_reg gs "git status shortcut"

gp() {
  git pull
}
_reg gp "git pull shortcut"

gb() {
  # fetch all remote branches
  git fetch --all --prune

  # track all remote branches locally
  for branch in $(git branch -r | grep -v '\->'); do
    git branch --track "${branch##*/}" "$branch" 2>/dev/null || true
  done

  # delete local branches that no longer exist on the remote
  for local_branch in $(git branch --format='%(refname:short)'); do
    if ! git show-ref --verify --quiet "refs/remotes/origin/$local_branch"; then
      echo "Deleting local branch $local_branch (no longer on remote)"
      git branch -d "$local_branch" 2>/dev/null || git branch -D "$local_branch"
    fi
  done
}
_reg gb "fetch all remote branches and create corresponding local branches"

gacp() {
  git add .
  git commit -m "$1"
  git push
}
_reg gacp "git add, commit, and push" "gacp <message>"

mkcd() {
  mkdir -p "$1"
  cd "$1"
}
_reg mkcd "make directory and switch in" "mkcd <dir>"

ubuntud() {
  local workdir="/root"

  # Start with an empty array for volume-mount arguments
  local -a volume_mount=()

  if [ -n "$1" ]; then
    local abs_path
    abs_path="$(cd "$1" && pwd)"  # absolute path
    workdir="/app"
    # Put '-v' and 'abs_path:/app' as separate array elements
    volume_mount=(-v "$abs_path:/app")
  fi

  # Now call docker using the array expansion: "${volume_mount[@]}"
  docker run \
    --tmpfs /var/cache/apt:size=1g \
    -e TZ=America/Denver \
    -e DEBIAN_FRONTEND=noninteractive \
    -w "$workdir" \
    -it --rm \
    -e INSIDE_CONTAINER=true \
    -v "$HOME/.zshrc:/root/.zshrc" \
    -v "$HOME/.functions:/root/.functions" \
    "${volume_mount[@]}" \
    ubuntu:noble \
    bash -c "$(cat <<'EOF'
      set -e
      echo "Starting your development container with zsh shell and pkgx on Ubuntu Noble..."

      apt update && apt install --no-install-recommends -y \
        zsh software-properties-common python3.12-venv git libssl-dev curl \
        neovim ripgrep build-essential ca-certificates libstdc++6

      ln -sf /usr/bin/python3 /usr/bin/python

      curl -fsSL https://pkgx.sh | sh

      exec zsh
EOF
    )"
}
_reg ubuntud "start an ubuntu container in interactive mode" "ubuntud [path]"

venv() {
    BLUE="\033[1;34m"
    GREEN="\033[1;32m"
    RESET="\033[0m"

    if [[ -d ".venv" ]]; then
        echo -e "${BLUE}Activating virtual environment...${RESET}"
        source .venv/bin/activate
    else
        echo "No virtual environment found."
        read -q "REPLY?Would you like to create one? (y/n) "
        echo  # move to a new line after read -q
        if [[ "$REPLY" == "y" ]]; then
            echo "Creating virtual environment..."
            pkgx python@3.11 -m venv .venv
            echo -e "${GREEN}Virtual environment created.${RESET}"
            echo -e "${BLUE}Activating virtual environment...${RESET}"
            source .venv/bin/activate
        fi
    fi
}
_reg venv "activate or create a virtual environment"

kg() {
    kubectl get "$1"
}
_reg kg "kubectl get" "kg <resource>"

kl() {
    kubectl logs "$1"
}
_reg kl "kubectl logs" "kl <pod>"

kd() {
    kubectl describe "$1" "$2"
}
_reg kd "kubectl describe" "kd <resource> <name>"

cpwd() {
  local p
  p=$(pwd)
  print -rn -- "$p" | pbcopy
  print -r -- "copied $p"
}
_reg cpwd "copy current directory path to clipboard"

gl() {
  keifu
}
_reg gl "open keifu git log viewer"

ports() {
  lsof -i -P -n | grep LISTEN
}
_reg ports "list all listening ports"

ip() {
  curl -s ifconfig.me
  echo
}
_reg ip "show public IP address"

_send_message() {
  local recipient=$SPECIAL_CONTACT_NUMBER_OR_EMAIL
  local message="$1"

  # Use AppleScript to send an iMessage
  osascript <<EOF
tell application "Messages"
    set recipient to "$recipient"
    set targetService to 1st service whose service type = iMessage
    set targetBuddy to buddy recipient of targetService
    if targetBuddy is not missing value then
        send "$message" to targetBuddy
    else
        error "Recipient not found or not available for iMessage."
    end if
end tell
EOF
}

notify() {
  local command_output
  command_output=$("$@" 2>&1)  # Capture both stdout and stderr
  local exit_code=$?

  if [ $exit_code -ne 0 ]; then
    # failure
    _send_message "'$*' - FAILURE \n---:\n$command_output"
  else
    # success
    _send_message "'$*' - SUCCESS\n---\n$command_output"
  fi
}
_reg notify "send an imessage of some results" "notify <command>"
